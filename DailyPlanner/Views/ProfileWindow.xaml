<Window x:Class="DailyPlanner.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_Profile}" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}"
        FontFamily="Segoe UI">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Taraf: Şablon Listesi -->
        <Border Grid.Column="0" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Text_MyTemplates}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                
                <Button DockPanel.Dock="Bottom" Content="{DynamicResource Text_NewTemplate}" Click="AddTemplate_Click"
                        Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,10,0,0" Cursor="Hand"/>
                
                <ListBox x:Name="TemplateList" ItemsSource="{Binding PageTemplates}" SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4" Width="200">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="✕" Width="24" Height="24" Background="Transparent" BorderThickness="0"
                                        Foreground="#EF4444" Cursor="Hand" Click="DeleteTemplate_Click" Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SidebarBtnActiveBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Sağ Taraf: Şablon Detayı (Görevler) -->
        <Border Grid.Column="1" Margin="10,0,0,0">
            <DockPanel IsEnabled="{Binding IsTemplateSelected}">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                    <TextBlock Text="{DynamicResource Text_TemplateName}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="20" FontWeight="Bold" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="{DynamicResource Text_Cancel}" Click="Close_Click" Width="80" Padding="8" Margin="0,0,10,0"
                            Background="{DynamicResource ContentBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    <Button Content="{DynamicResource Text_SaveAndApply}" Click="Save_Click" Width="140" Padding="8"
                            Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>

                <!-- Şablon Görevleri Listesi -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding SelectedTemplate.Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource TaskHoverBrush}" Foreground="{DynamicResource PrimaryTextBrush}"
                                                 BorderThickness="0" Padding="8" FontSize="14" Margin="0,0,10,0"/>
                                        <Button Grid.Column="1" Content="{DynamicResource Text_DeleteText}" Tag="{Binding}" Click="DeleteTask_Click"
                                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SecondaryTextBrush}" Cursor="Hand"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Görev Ekle Butonu -->
                        <Button Content="{DynamicResource Text_ProfileAddTask}" Click="AddTask_Click" HorizontalAlignment="Left"
                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,10,0,0" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
