            <!-- ════════════════════ TAB 9: SUPPLEMENT TESTİ ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_Supplement}">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_Supplement}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_Supplement}"/>

                        <!-- ── BÖLÜM 1: TEMEL BİLGİLER ── -->
