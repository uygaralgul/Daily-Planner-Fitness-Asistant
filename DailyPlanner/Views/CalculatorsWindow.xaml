                                    <TextBlock Text="{DynamicResource Sup_Digestion}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider x:Name="SupDigestion" Minimum="0" Maximum="10" Value="5"
                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                <DockPanel>
                                    <TextBlock Text="0" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="10" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                                <TextBlock Text="{DynamicResource Sup_DigestionDesc}" FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,14"/>

                                <!-- SEBZE MEYVE -->
                                <DockPanel Margin="0,0,0,2">
                                    <Border DockPanel.Dock="Right" Background="{DynamicResource AccentLightBrush}"
                                            CornerRadius="6" Padding="10,4" MinWidth="36">
                                        <TextBlock Text="{Binding ElementName=SupVeggie, Path=Value, StringFormat={}{0:F0}}"
                                                   FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Sup_VeggieFruit}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
