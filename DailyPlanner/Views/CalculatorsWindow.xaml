<Window x:Class="DailyPlanner.Views.CalculatorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_Calculators}" Height="640" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource ContentBackgroundBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/app_logo.png">

    <Window.Resources>
        <!-- ── Labels ── -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Calculate Button ── -->
        <Style x:Key="CalcBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Result Card ── -->
        <Style x:Key="ResultBox" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="ResultTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style x:Key="ResultDetail" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- ── Gender Toggle ── -->
        <Style x:Key="GenderBtn" TargetType="RadioButton">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Styled ComboBox ── -->
        <Style x:Key="StyledCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── Section Divider ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Padding="24,18" Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="🧠"
                        FontSize="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource ToolTip_MindGuide}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Click="MindGuideBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Anatomi Haritası button -->
                <Button DockPanel.Dock="Right"
                        Content="🦴"
                        FontSize="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource ToolTip_AnatomyMap}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Click="AnatomyBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Sporcu Rehberi button -->
                <Button DockPanel.Dock="Right"
                        Content="📚"
                        FontSize="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource ToolTip_SportGuide}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Click="SportGuideBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Calorie burn button (right, info'nun solu) -->
                <Button DockPanel.Dock="Right"
                        Content="🏃"
                        FontSize="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource ToolTip_CalorieBurn}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Click="CalorieBurnBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Info button (right) -->
                <Button DockPanel.Dock="Right"
                        Content="ℹ️"
                        FontSize="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource ToolTip_MeasurementGuide}"
                        VerticalAlignment="Center"
                        Click="InfoBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Title (left) -->
                <StackPanel>
                    <TextBlock Text="{DynamicResource Title_FitnessCalculators}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text=""
                               FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,3,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── TabControl ── -->
        <TabControl x:Name="MainTabs" Grid.Row="1" BorderThickness="0"
                    Background="{DynamicResource ContentBackgroundBrush}">
            <!-- WrapPanel: sekmelerin satır değiştirmesini önler -->
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="12,10">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ════════════════════ TAB 1: RIR ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_RIR}" ToolTip="RIR — Reps In Reserve: 1RM ve önerilen antrenman yükleri">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_Rir}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_Rir}"/>

                        <TextBlock Text="{DynamicResource Label_WorkingWeight}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="RirWeight" Style="{StaticResource InputBox}" Text="80"/>

                        <TextBlock Text="{DynamicResource Label_RepsDone}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="RirReps" Style="{StaticResource InputBox}" Text="6"/>

                        <TextBlock Text="{DynamicResource Label_RIR}" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="RirValue" Style="{StaticResource StyledCombo}" SelectedIndex="1">
                            <ComboBoxItem Content="{DynamicResource Rir_0}"/>
                            <ComboBoxItem Content="{DynamicResource Rir_1}"/>
                            <ComboBoxItem Content="{DynamicResource Rir_2}"/>
                            <ComboBoxItem Content="{DynamicResource Rir_3}"/>
                            <ComboBoxItem Content="{DynamicResource Rir_4}"/>
                        </ComboBox>

                        <Button Content="{DynamicResource Btn_CalcPower}" Style="{StaticResource CalcBtn}"
                                Click="CalcRIR_Click"/>

                        <Border x:Name="RirResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="RirResultText" Style="{StaticResource ResultTitle}"/>
                                <TextBlock x:Name="RirDetailText" Style="{StaticResource ResultDetail}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════ TAB 2: VÜCUT YAĞI ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_BodyFat}" ToolTip="Vücut Yağ Oranı — ABD Donanması (Navy) formülüyle hesaplama">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_BodyFat}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_BodyFat}"/>

                        <TextBlock Text="{DynamicResource Label_Gender}" Style="{StaticResource InputLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="BfMale" Content="{DynamicResource Label_Male}" IsChecked="True"
                                          Style="{StaticResource GenderBtn}" Margin="0,0,8,0" GroupName="BfGender"
                                          Checked="BfMale_Checked"/>
                            <RadioButton x:Name="BfFemale" Content="{DynamicResource Label_Female}"
                                          Style="{StaticResource GenderBtn}" GroupName="BfGender"
                                          Checked="BfFemale_Checked"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Label_Height}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BfHeight" Style="{StaticResource InputBox}" Text="175"/>

                        <TextBlock Text="{DynamicResource Label_Neck}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BfNeck" Style="{StaticResource InputBox}" Text="37"/>

                        <TextBlock Text="{DynamicResource Label_Waist}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BfWaist" Style="{StaticResource InputBox}" Text="82"/>

                        <TextBlock x:Name="HipLabel" Text="{DynamicResource Label_Hip}"
                                   Style="{StaticResource InputLabel}" Visibility="Collapsed"/>
                        <TextBox x:Name="BfHip" Style="{StaticResource InputBox}" Text="95"
                                 Visibility="Collapsed"/>

                        <Button Content="{DynamicResource Btn_CalcChart}" Style="{StaticResource CalcBtn}"
                                Click="CalcBodyFat_Click"/>

                        <Border x:Name="BfResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="BfResultText" Style="{StaticResource ResultTitle}"/>
                                <TextBlock x:Name="BfCategoryText" Style="{StaticResource ResultDetail}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════ TAB 3: KALORİ ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_Calories}" ToolTip="Günlük Kalori İhtiyacı — BMR ve TDEE (Mifflin-St Jeor)">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_Calories}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_Calories}"/>

                        <TextBlock Text="{DynamicResource Label_Gender}" Style="{StaticResource InputLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="BmrMale" Content="{DynamicResource Label_Male}" IsChecked="True"
                                          Style="{StaticResource GenderBtn}" Margin="0,0,8,0" GroupName="BmrGender"/>
                            <RadioButton x:Name="BmrFemale" Content="{DynamicResource Label_Female}"
                                          Style="{StaticResource GenderBtn}" GroupName="BmrGender"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Label_Weight}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BmrWeight" Style="{StaticResource InputBox}" Text="75"/>

                        <TextBlock Text="{DynamicResource Label_Height}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BmrHeight" Style="{StaticResource InputBox}" Text="175"/>

                        <TextBlock Text="{DynamicResource Label_Age}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BmrAge" Style="{StaticResource InputBox}" Text="25"/>

                        <TextBlock Text="{DynamicResource Label_ActivityLevel}" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="BmrActivity" Style="{StaticResource StyledCombo}" SelectedIndex="1">
                            <ComboBoxItem Content="{DynamicResource Act_1}"/>
                            <ComboBoxItem Content="{DynamicResource Act_2}"/>
                            <ComboBoxItem Content="{DynamicResource Act_3}"/>
                            <ComboBoxItem Content="{DynamicResource Act_4}"/>
                            <ComboBoxItem Content="{DynamicResource Act_5}"/>
                        </ComboBox>

                        <Button Content="{DynamicResource Btn_CalcFood}" Style="{StaticResource CalcBtn}"
                                Click="CalcBMR_Click"/>

                        <Border x:Name="BmrResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="BmrResultText" Style="{StaticResource ResultTitle}"/>
                                <TextBlock x:Name="BmrDetailText" Style="{StaticResource ResultDetail}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════ TAB 4: MAKRO ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_Macros}" ToolTip="Makro Besin Hesaplayıcı — Protein, karbonhidrat ve yağ gram miktarları">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_Macros}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_Macros}"/>

                        <TextBlock Text="{DynamicResource Label_TargetCal}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="MacroCalories" Style="{StaticResource InputBox}" Text="2500"/>

                        <TextBlock Text="{DynamicResource Label_Weight}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="MacroWeight" Style="{StaticResource InputBox}" Text="75"/>

                        <TextBlock Text="{DynamicResource Label_Goal}" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="MacroGoal" Style="{StaticResource StyledCombo}" SelectedIndex="1">
                            <ComboBoxItem Content="{DynamicResource Goal_Cut}"/>
                            <ComboBoxItem Content="{DynamicResource Goal_Maintain}"/>
                            <ComboBoxItem Content="{DynamicResource Goal_Bulk}"/>
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Label_WorkoutType}" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="MacroActivity" Style="{StaticResource StyledCombo}" SelectedIndex="1">
                            <ComboBoxItem Content="{DynamicResource Work_1}"/>
                            <ComboBoxItem Content="{DynamicResource Work_2}"/>
                            <ComboBoxItem Content="{DynamicResource Work_3}"/>
                        </ComboBox>

                        <Button Content="{DynamicResource Btn_CalcBroccoli}" Style="{StaticResource CalcBtn}"
                                Click="CalcMacro_Click"/>

                        <Border x:Name="MacroResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="MacroResultText" Style="{StaticResource ResultTitle}"/>
                                <TextBlock x:Name="MacroDetailText" Style="{StaticResource ResultDetail}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════ TAB 5: VKİ ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_BMI}" ToolTip="Vücut Kitle İndeksi (BMI) — WHO sınıflandırması ile kilo kategoriniz">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Title_BMI}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource Desc_BMI}"/>

                        <TextBlock Text="{DynamicResource Label_Weight}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BmiWeight" Style="{StaticResource InputBox}" Text="75"/>

                        <TextBlock Text="{DynamicResource Label_Height}" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="BmiHeight" Style="{StaticResource InputBox}" Text="175"/>

                        <Button Content="{DynamicResource Btn_CalcScale}" Style="{StaticResource CalcBtn}"
                                Click="CalcBMI_Click"/>

                        <Border x:Name="BmiResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="BmiResultText" Style="{StaticResource ResultTitle}"/>
                                <TextBlock x:Name="BmiCategoryText" Style="{StaticResource ResultDetail}"/>

                                <!-- VKİ Scale Visual -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Height="6" Background="#5DADE2" CornerRadius="3,0,0,3"/>
                                    <Border Grid.Column="1" Height="6" Background="#58D68D"/>
                                    <Border Grid.Column="2" Height="6" Background="#F4D03F"/>
                                    <Border Grid.Column="3" Height="6" Background="#E67E22"/>
                                    <Border Grid.Column="4" Height="6" Background="#E74C3C" CornerRadius="0,3,3,0"/>
                                </Grid>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Label_Underweight}" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource Label_Normal}" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Label_Overweight}" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{DynamicResource Label_Obese1}" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{DynamicResource Label_Obese2}" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </Grid>
                                <TextBlock x:Name="BmiIndicatorText" Style="{StaticResource ResultDetail}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ════════════════════ TAB 6: KİLO HEDEFİ ════════════════════ -->
            <TabItem Header="{DynamicResource Tab_WeightGoal}" ToolTip="Kilo Hedefi Ulaşılabilirlik Analizi — Süreye göre haftalık değişim hızı ve sağlık değerlendirmesi">
                <ScrollViewer Padding="24,18" VerticalScrollBarVisibility="Auto">
