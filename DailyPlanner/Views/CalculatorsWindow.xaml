                                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider x:Name="SupWeight" Minimum="30" Maximum="200" Value="80"
                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                <DockPanel>
                                    <TextBlock Text="30 kg" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="200 kg" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"/>
