                                CornerRadius="0,10,10,0" Background="{DynamicResource WindowBackgroundBrush}" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sup_Section1}" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>

                                <!-- KİLO -->
                                <DockPanel Margin="0,0,0,2">
                                    <Border DockPanel.Dock="Right" Background="{DynamicResource AccentLightBrush}"
                                            CornerRadius="6" Padding="10,4" MinWidth="55">
                                        <TextBlock Text="{Binding ElementName=SupWeight, Path=Value, StringFormat={}{0:F0} kg}"
                                                   FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
