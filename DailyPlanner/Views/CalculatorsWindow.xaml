                                    <RadioButton x:Name="SupWTNo" Content="{DynamicResource Sup_No}"
                                                 Style="{StaticResource GenderBtn}" GroupName="SupWT"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── BÖLÜM 2: BESLENME ANALİZİ ── -->
