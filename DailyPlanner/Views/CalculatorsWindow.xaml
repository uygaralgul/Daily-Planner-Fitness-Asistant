                                <TextBlock Text="{DynamicResource Sup_MealRegularityDesc}" FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,14"/>

