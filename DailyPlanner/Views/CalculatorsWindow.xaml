                                CornerRadius="0,10,10,0" Background="{DynamicResource WindowBackgroundBrush}" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sup_Section2}" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>

