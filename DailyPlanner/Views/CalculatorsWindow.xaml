                                <TextBlock Text="{DynamicResource Sup_WeightDesc}" FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,12"/>

                                <!-- ANALİZ TÜRÜ -->
                                <TextBlock Text="{DynamicResource Sup_AnalysisType}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8"
                                        Padding="12,10" Margin="0,0,0,4" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <RadioButton x:Name="SupAnalysisMinimal" GroupName="SupAnalysis" IsChecked="True"
                                                 Foreground="{DynamicResource PrimaryTextBrush}">
                                        <TextBlock Text="{DynamicResource Sup_AnalysisMinimal}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                                    </RadioButton>
                                </Border>
                                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8"
                                        Padding="12,10" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
