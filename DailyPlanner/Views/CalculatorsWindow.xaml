                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
                                <DockPanel>
                                    <TextBlock Text="0" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="10" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                                <TextBlock Text="{DynamicResource Sup_TrainingEnergyDesc}" FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,16"/>

                                <!-- ANTRENMAN CHECKLIST -->
                                <TextBlock Text="{DynamicResource Sup_TrainingTitle}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                <CheckBox x:Name="SupChkTrainOk" Margin="0,3" Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Sup_ChkTrainOk}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                                </CheckBox>
                                <CheckBox x:Name="SupChkWeakPump" Margin="0,3" Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Sup_ChkWeakPump}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                                </CheckBox>
                                <CheckBox x:Name="SupChkTrainFaint" Margin="0,3" Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Sup_ChkTrainFaint}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- ANALİZ BUTTON -->
                        <Button Content="{DynamicResource Btn_AnalyzeSupplement}" Style="{StaticResource CalcBtn}"
                                Click="CalcSupplement_Click"/>

                        <!-- SONUÇLAR -->
                        <Border x:Name="SupResult" Style="{StaticResource ResultBox}" Visibility="Collapsed">
                            <StackPanel x:Name="SupResultPanel"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

    </Grid>
</Window>

