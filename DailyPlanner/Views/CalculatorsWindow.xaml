                                           Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- ── BÖLÜM 3: YAŞAM TARZI & BELİRTİLER ── -->
                        <Border Margin="0,12,0,0" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="3,0,0,0"
                                CornerRadius="0,10,10,0" Background="{DynamicResource WindowBackgroundBrush}" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Sup_Section3}" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>

                                <!-- UYKU -->
                                <DockPanel Margin="0,0,0,2">
                                    <Border DockPanel.Dock="Right" Background="{DynamicResource AccentLightBrush}"
                                            CornerRadius="6" Padding="10,4" MinWidth="36">
                                        <TextBlock Text="{Binding ElementName=SupSleep, Path=Value, StringFormat={}{0:F0}}"
