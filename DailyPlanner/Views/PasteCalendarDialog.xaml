<Window x:Class="DailyPlanner.Views.PasteCalendarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DailyPlanner.Converters"
        Title="{DynamicResource Title_PasteDays}"
        Width="420" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBackgroundBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/app_logo.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Text_SelectDaysToPaste}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock x:Name="SubTitle"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Month navigator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnPrev" Content="◀" Width="30" Height="30"
                    Background="{DynamicResource NavBtnBrush}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnPrev_Click" FontSize="11"
                    Foreground="{DynamicResource PrimaryTextBrush}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock x:Name="MonthLabel"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
            <Button x:Name="BtnNext" Content="▶" Width="30" Height="30"
                    Background="{DynamicResource NavBtnBrush}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnNext_Click" FontSize="11"
                    Foreground="{DynamicResource PrimaryTextBrush}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Day grid (7 columns) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Day names header -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Text_Mon}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource Text_Tue}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="2" Text="{DynamicResource Text_Wed}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="3" Text="{DynamicResource Text_Thu}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="4" Text="{DynamicResource Text_Fri}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="5" Text="{DynamicResource Text_Sat}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                    <TextBlock Grid.Column="6" Text="{DynamicResource Text_Sun}" HorizontalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                </Grid>

                <ItemsControl x:Name="DayGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" Rows="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="50" Height="46" Margin="1" CornerRadius="8"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Day_Click"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CalDayBgBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DayNumber}" FontSize="14" FontWeight="SemiBold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource CalDayTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Text_Cancel}" Width="90" Height="36" Margin="0,0,8,0"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    Cursor="Hand"
                    Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="{DynamicResource Text_PasteText}" Width="100" Height="36"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Click="Paste_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
