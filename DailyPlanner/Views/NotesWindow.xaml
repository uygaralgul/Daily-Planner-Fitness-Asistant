<Window x:Class="DailyPlanner.Views.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_Notes}" Height="580" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing"
        Icon="/Assets/app_logo.png">

    <Window.Resources>
        <Style x:Key="NoteListBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SidebarBtnHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar buton stili -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Toolbar buton stili -->
        <Style x:Key="ToolbarToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentLightBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Note List ===== -->
        <Border Grid.Column="0"
                x:Name="SidebarBorder"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,14"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Renk değiştir butonu -->
                        <Button DockPanel.Dock="Right"
                                x:Name="SidebarColorBtn"
                                Foreground="#EF4444"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{DynamicResource Text_SidebarColor}"
                                Click="SidebarColorBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="4,2" CornerRadius="5">
                                        <Path Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 13.1 22 14 21.1 14 20 C 14 19.46 13.79 18.96 13.43 18.59 C 13.08 18.23 13.06 17.9 13.06 17.75 C 13.06 17.2 13.51 16.75 14.06 16.75 L 15.5 16.75 C 19.09 16.75 22 13.84 22 10.25 C 22 5.69 17.52 2 12 2 Z M 6.5 11.5 C 5.67 11.5 5 10.83 5 10 C 5 9.17 5.67 8.5 6.5 8.5 C 7.33 8.5 8 9.17 8 10 C 8 10.83 7.33 11.5 6.5 11.5 Z M 9.5 7.5 C 8.67 7.5 8 6.83 8 6 C 8 5.17 8.67 4.5 9.5 4.5 C 10.33 4.5 11 5.17 11 6 C 11 6.83 10.33 7.5 9.5 7.5 Z M 14.5 7.5 C 13.67 7.5 13 6.83 13 6 C 13 5.17 13.67 4.5 14.5 4.5 C 15.33 4.5 16 5.17 16 6 C 16 6.83 15.33 7.5 14.5 7.5 Z M 17.5 11.5 C 16.67 11.5 16 10.83 16 10 C 16 9.17 16.67 8.5 17.5 8.5 C 18.33 8.5 19 9.17 19 10 C 19 10.83 18.33 11.5 17.5 11.5 Z" 
                                              Fill="{TemplateBinding Foreground}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="{DynamicResource Text_MyNotes}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="White"
                                   Opacity="0.9"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Add Note Button -->
                <Button DockPanel.Dock="Bottom"
                        Margin="8,8"
                        Click="AddNote_Click"
                        Style="{StaticResource NoteListBtn}"
                        Background="{DynamicResource AccentLightBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Text_NewNote}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Note List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="NoteList" Margin="0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button Style="{StaticResource NoteListBtn}"
                                            Tag="{Binding}"
                                            Click="NoteItem_Click">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                                       FontSize="10"
                                                       Foreground="White" Opacity="0.65"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== RIGHT: Editor ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Padding="20,14"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="{DynamicResource Text_Delete}"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="#EF4444"
                            Click="DeleteNote_Click"
                            x:Name="DeleteBtn"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="8,4" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFE5E5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Reminder button -->
                    <Button DockPanel.Dock="Right"
                            x:Name="ReminderBtn"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="{DynamicResource AccentBrush}"
                            Margin="0,0,8,0"
                            Click="AddReminder_Click"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="8,4" CornerRadius="6"
                                        x:Name="ReminderBd">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBox x:Name="NoteTitleBox"
                             Text="{DynamicResource Text_SelectOrCreateNote}"
                             FontSize="16" FontWeight="SemiBold"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             IsEnabled="False"
                             VerticalAlignment="Center"
                             KeyDown="NoteTitleBox_KeyDown"
                             TextChanged="NoteTitleBox_TextChanged"/>
                </DockPanel>
            </Border>

            <!-- ===== FORMAT TOOLBAR ===== -->
            <Border Grid.Row="1"
                    x:Name="FormatToolbar"
                    Padding="12,6"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <WrapPanel Orientation="Horizontal">
                    <!-- Bold -->
                    <ToggleButton Style="{StaticResource ToolbarToggleBtn}"
                                  ToolTip="{DynamicResource Text_Bold}"
                                  Click="Bold_Click" x:Name="BoldBtn">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </ToggleButton>
                    <!-- Italic -->
                    <ToggleButton Style="{StaticResource ToolbarToggleBtn}"
                                  ToolTip="{DynamicResource Text_Italic}"
                                  Click="Italic_Click" x:Name="ItalicBtn">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="14"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </ToggleButton>
                    <!-- Underline -->
                    <ToggleButton Style="{StaticResource ToolbarToggleBtn}"
                                  ToolTip="{DynamicResource Text_Underline}"
                                  Click="Underline_Click" x:Name="UnderlineBtn">
                        <TextBlock FontSize="14" Foreground="{DynamicResource PrimaryTextBrush}">
                            <Underline>U</Underline>
                        </TextBlock>
                    </ToggleButton>

                    <!-- Ayırıcı -->
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}"
                            Margin="6,0"/>

                    <!-- Yazı boyutu -->
                    <ComboBox x:Name="FontSizeBox"
                              Width="60" Height="26"
                              FontSize="11"
                              SelectionChanged="FontSize_Changed"
                              ToolTip="{DynamicResource Text_FontSize}">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="14" IsSelected="True"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="18"/>
                        <ComboBoxItem Content="20"/>
                        <ComboBoxItem Content="24"/>
                        <ComboBoxItem Content="28"/>
                        <ComboBoxItem Content="32"/>
                    </ComboBox>

                    <!-- Ayırıcı -->
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}"
                            Margin="6,0"/>

                    <!-- Yazı rengi paleti -->
                    <TextBlock Text="A" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="4,0,4,0"
                               ToolTip="{DynamicResource Text_SelectColor}"/>

                    <!-- Renk noktaları -->
                    <Button x:Name="TextColorBtn1" Width="18" Height="18" Margin="2,0"
                            Background="#EF4444" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Red}"
                            Click="TextColorBtn_Click" Tag="#EF4444">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn2" Width="18" Height="18" Margin="2,0"
                            Background="#F97316" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Orange}"
                            Click="TextColorBtn_Click" Tag="#F97316">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn3" Width="18" Height="18" Margin="2,0"
                            Background="#EAB308" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Yellow}"
                            Click="TextColorBtn_Click" Tag="#EAB308">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn4" Width="18" Height="18" Margin="2,0"
                            Background="#22C55E" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Green}"
                            Click="TextColorBtn_Click" Tag="#22C55E">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn5" Width="18" Height="18" Margin="2,0"
                            Background="#3B82F6" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Blue}"
                            Click="TextColorBtn_Click" Tag="#3B82F6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn6" Width="18" Height="18" Margin="2,0"
                            Background="#A855F7" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Purple}"
                            Click="TextColorBtn_Click" Tag="#A855F7">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="TextColorBtn7" Width="18" Height="18" Margin="2,0"
                            Background="#EC4899" BorderThickness="0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_Pink}"
                            Click="TextColorBtn_Click" Tag="#EC4899">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="18" Height="18"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Varsayılan renk (tema rengi) -->
                    <Button x:Name="TextColorBtn8" Width="18" Height="18" Margin="2,0"
                            Cursor="Hand" ToolTip="{DynamicResource Text_DefaultColor}"
                            Click="TextColorBtn_Click" Tag="default">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{DynamicResource PrimaryTextBrush}" CornerRadius="4"
                                        Width="18" Height="18" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1.5"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </WrapPanel>
            </Border>

            <!-- Content editor — RichTextBox -->
            <RichTextBox x:Name="NoteContentBox"
                         Grid.Row="2"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         FontSize="14"
                         Padding="20,16"
                         IsEnabled="False"
                         TextChanged="NoteContentBox_TextChanged"
                         SelectionChanged="NoteContentBox_SelectionChanged"
                         SpellCheck.IsEnabled="True">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>

            <!-- Status bar -->
            <Border Grid.Row="3"
                    Padding="20,8"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText"
                           Text="{DynamicResource Text_SelectNote}"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </Border>
        </Grid>

        <!-- Empty state overlay -->
        <Border Grid.Column="1" x:Name="EmptyState"
                Background="{DynamicResource ContentBackgroundBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="{DynamicResource Text_NoNotesYet}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                <TextBlock Text="{DynamicResource Text_EmptyNoteGuidance}"
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
