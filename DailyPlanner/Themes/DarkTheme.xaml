<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === DARK THEME === -->

    <!-- Window & backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"   Color="#0F172A"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush"  Color="#1E293B"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"   Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"  Color="#1E1B4B"/>
    <SolidColorBrush x:Key="CalendarBandBrush"       Color="#1E293B"/>
    <SolidColorBrush x:Key="RightPanelBrush"         Color="#1A2035"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"             Color="#334155"/>
    <SolidColorBrush x:Key="SubtleBorderBrush"       Color="#1E293B"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"        Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"      Color="#94A3B8"/>
    <SolidColorBrush x:Key="SidebarTextBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarSubTextBrush"     Color="#A5B4FC"/>
    <SolidColorBrush x:Key="CompletedTextBrush"      Color="#475569"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"             Color="#818CF8"/>
    <SolidColorBrush x:Key="AccentLightBrush"        Color="#1E1B4B"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="#6366F1"/>

    <!-- Sidebar buttons -->
    <SolidColorBrush x:Key="SidebarBtnHoverBrush"   Color="#312E81"/>
    <SolidColorBrush x:Key="SidebarBtnActiveBrush"  Color="#6366F1"/>

    <!-- Tasks -->
    <SolidColorBrush x:Key="TaskHoverBrush"          Color="#1A2035"/>
    <SolidColorBrush x:Key="CheckboxActiveBrush"     Color="#818CF8"/>

    <!-- Action buttons -->
    <SolidColorBrush x:Key="ActionBtn1Brush"         Color="#6366F1"/>
    <SolidColorBrush x:Key="ActionBtn2Brush"         Color="#0284C7"/>
    <SolidColorBrush x:Key="ActionBtn3Brush"         Color="#059669"/>

    <!-- Calendar day circle -->
    <SolidColorBrush x:Key="CalDayBgBrush"           Color="#334155"/>
    <SolidColorBrush x:Key="CalDayTextBrush"         Color="#CBD5E1"/>
    <SolidColorBrush x:Key="CalDaySelectedBrush"     Color="#818CF8"/>
    <SolidColorBrush x:Key="CalDayTodayBgBrush"      Color="#1E1B4B"/>

    <!-- Nav buttons -->
    <SolidColorBrush x:Key="NavBtnBrush"             Color="#334155"/>
    <SolidColorBrush x:Key="NavBtnHoverBrush"        Color="#475569"/>

    <!-- Page tab -->
    <SolidColorBrush x:Key="TabActiveBrush"          Color="#818CF8"/>
    <SolidColorBrush x:Key="TabActiveTextBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabInactiveBrush"        Color="#334155"/>
    <SolidColorBrush x:Key="TabInactiveTextBrush"    Color="#94A3B8"/>

</ResourceDictionary>
