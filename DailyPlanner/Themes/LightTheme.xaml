<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === LIGHT THEME === -->

    <!-- Window & backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"   Color="#F0F2F7"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"  Color="#2D3561"/>
    <SolidColorBrush x:Key="CalendarBandBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="RightPanelBrush"         Color="#F8FAFF"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"             Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SubtleBorderBrush"       Color="#F1F5F9"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"        Color="#1E293B"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"      Color="#64748B"/>
    <SolidColorBrush x:Key="SidebarTextBrush"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarSubTextBrush"     Color="#A5B4FC"/>
    <SolidColorBrush x:Key="CompletedTextBrush"      Color="#94A3B8"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"             Color="#4F46E5"/>
    <SolidColorBrush x:Key="AccentLightBrush"        Color="#EEF2FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="#4338CA"/>

    <!-- Sidebar buttons -->
    <SolidColorBrush x:Key="SidebarBtnHoverBrush"   Color="#3D4A7A"/>
    <SolidColorBrush x:Key="SidebarBtnActiveBrush"  Color="#4F46E5"/>

    <!-- Tasks -->
    <SolidColorBrush x:Key="TaskHoverBrush"          Color="#F8FAFF"/>
    <SolidColorBrush x:Key="CheckboxActiveBrush"     Color="#4F46E5"/>

    <!-- Action buttons -->
    <SolidColorBrush x:Key="ActionBtn1Brush"         Color="#4F46E5"/>
    <SolidColorBrush x:Key="ActionBtn2Brush"         Color="#0EA5E9"/>
    <SolidColorBrush x:Key="ActionBtn3Brush"         Color="#10B981"/>

    <!-- Calendar day circle -->
    <SolidColorBrush x:Key="CalDayBgBrush"           Color="#F1F5F9"/>
    <SolidColorBrush x:Key="CalDayTextBrush"         Color="#475569"/>
    <SolidColorBrush x:Key="CalDaySelectedBrush"     Color="#4F46E5"/>
    <SolidColorBrush x:Key="CalDayTodayBgBrush"      Color="#EEF2FF"/>

    <!-- Nav buttons -->
    <SolidColorBrush x:Key="NavBtnBrush"             Color="#F1F5F9"/>
    <SolidColorBrush x:Key="NavBtnHoverBrush"        Color="#E2E8F0"/>

    <!-- Page tab -->
    <SolidColorBrush x:Key="TabActiveBrush"          Color="#4F46E5"/>
    <SolidColorBrush x:Key="TabActiveTextBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabInactiveBrush"        Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TabInactiveTextBrush"    Color="#64748B"/>

</ResourceDictionary>
