    <!-- Supplements Definitions -->
    <system:String x:Key="Sup_01_Name">Creatine Monohydrate</system:String>
    <system:String x:Key="Sup_01_Dose">3–5 g/day</system:String>
    <system:String x:Key="Sup_01_Time">Every day at a fixed time, with or after a meal</system:String>
    <system:String x:Key="Sup_01_Note">The most well-studied supplement. Increases strength 5–15%, supports lean mass. No loading needed.</system:String>
    
    <system:String x:Key="Sup_02_Name">Whey Protein</system:String>
    <system:String x:Key="Sup_02_Dose">Target: ~{0:F0} g/day total protein ({1} g/kg)</system:String>
    <system:String x:Key="Sup_02_Time">Post-workout within 30–60 min, or to complete daily protein</system:String>
    <system:String x:Key="Sup_02_Note">Whey isolate is fastest absorbing. Not superior to real food — use to fill gaps.</system:String>
    
    <system:String x:Key="Sup_03_Name">Vitamin D3 + K2</system:String>
    <system:String x:Key="Sup_03_Dose">2000–4000 IU D3 + 100–200 mcg K2/day</system:String>
    <system:String x:Key="Sup_03_Time">With a fatty meal (fat-soluble)</system:String>
    <system:String x:Key="Sup_03_Note">50% of athletes are deficient. Supports muscle strength, hormonal balance, and immunity. Essential Oct–Apr.</system:String>
    
    <system:String x:Key="Sup_04_Name">Magnesium Bisglycinate</system:String>
    <system:String x:Key="Sup_04_Dose">200–400 mg/day</system:String>
    <system:String x:Key="Sup_04_Time">Glycinate form at bedtime for relaxation and deep sleep</system:String>
    <system:String x:Key="Sup_04_Note">60% of athletes are deficient. Reduces cramps, improves sleep quality, insulin sensitivity.</system:String>
    
    <system:String x:Key="Sup_05_Name">Omega-3 (EPA/DHA)</system:String>
    <system:String x:Key="Sup_05_Dose">2–3 g/day (≥1 g EPA)</system:String>
    <system:String x:Key="Sup_05_Time">With meals, consistently every day</system:String>
    <system:String x:Key="Sup_05_Note">Increases muscle protein synthesis, reduces post-exercise inflammation. Prefer fish oil.</system:String>

    <system:String x:Key="Sup_06_Name">Multivitamin / Multimineral</system:String>
    <system:String x:Key="Sup_06_Dose">1 tablet/day (per label directions)</system:String>
    <system:String x:Key="Sup_06_Time">With breakfast or lunch</system:String>
    <system:String x:Key="Sup_06_Note">Fills micronutrient gaps from poor diet variety. Not a substitute for real food.</system:String>

    <system:String x:Key="Sup_07_Name">Caffeine (Pre-workout)</system:String>
    <system:String x:Key="Sup_07_Dose">3–6 mg/kg → {0:F0}–{1:F0} mg</system:String>
    <system:String x:Key="Sup_07_Time">45–60 min before training. Avoid after 2 PM for sleep.</system:String>
    <system:String x:Key="Sup_07_Note">Improves endurance 2–4%, strength and focus. Take 1–2 days off/week for tolerance.</system:String>

    <system:String x:Key="Sup_08_Name">Probiotic</system:String>
    <system:String x:Key="Sup_08_Dose">10–50 billion CFU/day, multi-strain</system:String>
    <system:String x:Key="Sup_08_Time">On empty stomach in the morning or before bed</system:String>
    <system:String x:Key="Sup_08_Note">Restores gut flora balance. Look for Lactobacillus + Bifidobacterium strains.</system:String>

    <system:String x:Key="Sup_09_Name">Electrolyte</system:String>
    <system:String x:Key="Sup_09_Dose">Sodium 500–1500 mg, Potassium 200–400 mg per session</system:String>
    <system:String x:Key="Sup_09_Time">During and after training, especially in hot weather</system:String>
    <system:String x:Key="Sup_09_Note">Prevents dehydration and performance loss from excessive sweating.</system:String>

    <system:String x:Key="Sup_10_Name">Zinc + Vitamin C</system:String>
    <system:String x:Key="Sup_10_Dose">Zinc 15–30 mg + Vitamin C 500–1000 mg/day</system:String>
    <system:String x:Key="Sup_10_Time">With a meal (zinc can cause nausea on empty stomach)</system:String>
    <system:String x:Key="Sup_10_Note">Supports immune function, testosterone production, and antioxidant defense.</system:String>

    <system:String x:Key="Sup_11_Name">Beta-Alanine</system:String>
    <system:String x:Key="Sup_11_Dose">3.2–6.4 g/day</system:String>
    <system:String x:Key="Sup_11_Time">Split into small doses (0.8–1g × 4–6) to minimize tingling</system:String>
    <system:String x:Key="Sup_11_Note">Buffers pH in 60–240s exercises. Tingling is normal and harmless. Min 4 weeks for effect.</system:String>

    <system:String x:Key="Sup_12_Name">Fiber Supplement (Psyllium)</system:String>
    <system:String x:Key="Sup_12_Dose">5–10 g/day</system:String>
    <system:String x:Key="Sup_12_Time">With plenty of water, between meals</system:String>
    <system:String x:Key="Sup_12_Note">Improves digestion, increases satiety, regulates blood sugar.</system:String>

    <system:String x:Key="Sup_13_Name">Melatonin</system:String>
    <system:String x:Key="Sup_13_Dose">0.5–3 mg/day</system:String>
    <system:String x:Key="Sup_13_Time">30–60 min before bedtime, in a dark room</system:String>
    <system:String x:Key="Sup_13_Note">Start with the lowest dose (0.5 mg). For short-term use to reset sleep cycle.</system:String>

